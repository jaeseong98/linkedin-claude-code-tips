LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password

# 검색 키워드 (쉼표 구분)
SEARCH_KEYWORDS=Claude Code,MCP tips,Claude Code skills,Claude Code hooks

# 스케줄 실행 시각 (24시간제)
DAILY_RUN_TIME=09:00

# 게시글 최대 수집 수 (키워드당)
MAX_POSTS_PER_KEYWORD=20

# 마켓플레이스 레포 경로 (자동 publish용)
MARKETPLACE_REPO_PATH=C:\Users\your_username\claude-code-skills
